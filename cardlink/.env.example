# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Stripe secret/API keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# NFC card display price (no Stripe Price IDs needed — uses inline price_data)
NEXT_PUBLIC_NFC_CARD_PRICE_DISPLAY=58

# AI Provider — "copilot" | "poe" | "openai"
AI_PROVIDER=copilot

# GitHub Copilot (when AI_PROVIDER=copilot) — uses https://api.githubcopilot.com
GITHUB_TOKEN=your_github_token
# AI_COPILOT_DEFAULT_MODEL=gpt-4o

# POE (when AI_PROVIDER=poe) — uses OpenAI-compatible endpoint https://api.poe.com/v1
# AI_POE_API_KEY=your_poe_api_key
# AI_POE_DEFAULT_BOT=claude-haiku-4.5

# OpenAI-compatible (when AI_PROVIDER=openai)
# Also works with Azure OpenAI, Groq, Together AI, local Ollama, etc.
# AI_OPENAI_API_KEY=sk-xxx
# AI_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_OPENAI_DEFAULT_MODEL=gpt-4o-mini
